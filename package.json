{
  "name": "jq79",
  "version": "0.2.0",
  "description": "Mini reactive component library: single-file components, Svelte-style setup scripts, fine-grained proxy reactivity. One file, zero dependencies.",
  "keywords": [
    "reactive",
    "components",
    "single-file-components",
    "proxy",
    "mini",
    "ui"
  ],
  "homepage": "https://github.com/jgermade/jq79#readme",
  "bugs": {
    "url": "https://github.com/jgermade/jq79/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jgermade/jq79.git"
  },
  "license": "ISC",
  "author": "Jesus Germade <jesus@germade.dev>",
  "type": "module",
  "main": "./dist/jq79.cjs",
  "module": "./dist/jq79.js",
  "types": "./dist/jq79.d.ts",
  "exports": {
    ".": {
      "types": "./dist/jq79.d.ts",
      "import": "./dist/jq79.js",
      "require": "./dist/jq79.cjs",
      "default": "./dist/jq79.js"
    }
  },
  "unpkg": "./dist/jq79.global.js",
  "jsdelivr": "./dist/jq79.global.js",
  "files": [
    "dist",
    "src/jq79.ts"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && tsc src/jq79.ts --declaration --emitDeclarationOnly --strict --lib dom,es2020 --target es2020 --module es2020 --moduleResolution bundler --outDir dist",
    "test": "vitest run",
    "prepublishOnly": "npm test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "jsdom": "^29.1.1",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
