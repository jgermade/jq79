{
  "name": "jq79",
  "version": "0.3.22",
  "description": "Mini reactive component library: single-file components, Svelte-style setup scripts, fine-grained proxy reactivity. Single-file build, zero dependencies.",
  "keywords": [
    "reactive",
    "components",
    "single-file-components",
    "proxy",
    "mini",
    "ui"
  ],
  "homepage": "https://github.com/jgermade/jq79#readme",
  "bugs": {
    "url": "https://github.com/jgermade/jq79/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jgermade/jq79.git"
  },
  "license": "ISC",
  "author": "Jesus Germade <jesus@germade.dev>",
  "type": "module",
  "main": "./dist/jq79.cjs",
  "module": "./dist/jq79.js",
  "types": "./dist/jq79.d.ts",
  "exports": {
    ".": {
      "types": "./dist/jq79.d.ts",
      "import": "./dist/jq79.js",
      "require": "./dist/jq79.cjs",
      "default": "./dist/jq79.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs",
      "default": "./dist/vite.js"
    }
  },
  "unpkg": "./dist/jq79.global.js",
  "jsdelivr": "./dist/jq79.global.js",
  "files": [
    "dist",
    "src",
    "assets"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && tsc src/jq79.ts src/vite.ts --declaration --emitDeclarationOnly --strict --skipLibCheck --lib dom,es2020 --target es2020 --module es2020 --moduleResolution bundler --outDir dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "site": "node scripts/build-site.mjs",
    "site.dev": "node scripts/site-dev.mjs",
    "prepublishOnly": "npm test && npm run build"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "chokidar": "^5.0.0",
    "highlight.js": "^11.11.1",
    "jsdom": "^29.1.1",
    "marked": "^18.0.6",
    "marked-highlight": "^2.2.4",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
